{
  "mcpServers": {
    "salesforce-official": {
      "command": "node",
      "args": [
        "./backend/node_modules/@salesforce/mcp/bin/run.js",
        "-o", "YOUR_SF_USERNAME",
        "--toolsets", "data,users,core",
        "--no-telemetry"
      ]
    },
    "salesforce-admin": {
      "command": "node",
      "args": ["./backend/sfdc-mcp-server.js"],
      "env": {
        "SF_CONSUMER_KEY": "YOUR_CONNECTED_APP_CONSUMER_KEY",
        "SF_CONSUMER_SECRET": "YOUR_CONNECTED_APP_CONSUMER_SECRET",
        "SF_USERNAME": "YOUR_SF_USERNAME",
        "SF_PASSWORD": "YOUR_SF_PASSWORD",
        "SF_LOGIN_URL": "https://login.salesforce.com"
      }
    }
  }
}
