# ── Anthropic ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Salesforce Connected App (OAuth 2.0) ──────────────────────────────────
# Create a Connected App in Salesforce Setup:
#   Setup → App Manager → New Connected App
#   Enable OAuth Settings → check "Enable OAuth Settings"
#   Callback URL: http://localhost:3001/oauth/callback
#   Selected OAuth Scopes: api, refresh_token, offline_access
#   Under OAuth Policies → enable "Enable OAuth Username-Password Flows"
#
SF_CONSUMER_KEY=your_connected_app_consumer_key
SF_CONSUMER_SECRET=your_connected_app_consumer_secret

# ── Salesforce User Credentials ───────────────────────────────────────────
SF_USERNAME=admin@yourorg.com
SF_PASSWORD=yourpassword
# Security token is only needed when NOT using a Connected App or trusted IP
# SF_SECURITY_TOKEN=yourtoken

# ── Login URL ─────────────────────────────────────────────────────────────
# Dev/production org: https://login.salesforce.com
# Sandbox:            https://test.salesforce.com
SF_LOGIN_URL=https://login.salesforce.com

# ── Server ────────────────────────────────────────────────────────────────
PORT=3001
